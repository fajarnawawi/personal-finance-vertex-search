# ─────────────────────────────────────────────
# Google Cloud Platform
# ─────────────────────────────────────────────

# GCP project ID (e.g. finance-brain-yourname)
GCP_PROJECT_ID=finance-brain-yourname

# GCS bucket for indexed content (transcript chunks, PDFs, articles)
GCS_INGEST_BUCKET=finance-brain-ingest

# GCS bucket for receipt images
GCS_RECEIPTS_BUCKET=finance-brain-receipts

# BigQuery dataset name (default: finance_brain)
BIGQUERY_DATASET=finance_brain

# ─────────────────────────────────────────────
# Vertex AI Search (Discovery Engine)
# ─────────────────────────────────────────────

# Media datastore ID — created by infra/scripts/create_datastores.sh
# Format: projects/{project}/locations/global/collections/default_collection/dataStores/{id}
VERTEX_MEDIA_DATASTORE_ID=finance-brain-media_1234567890

# Generic datastore ID
VERTEX_GENERIC_DATASTORE_ID=finance-brain-generic_1234567890

# ─────────────────────────────────────────────
# Gemini / Vertex AI
# ─────────────────────────────────────────────

# Gemini model to use for extraction and answer generation
GEMINI_MODEL=gemini-2.5-flash

# Minimum grounding score before adding a low-confidence warning footer (0.0–1.0)
GROUNDING_SCORE_THRESHOLD=0.7

# ─────────────────────────────────────────────
# Telegram
# ─────────────────────────────────────────────

# Bot token from @BotFather (format: 123456789:ABCdef...)
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrSTUvwxYZ

# Your personal Telegram user ID (from @userinfobot) — only this ID can use the bot
TELEGRAM_ALLOWED_USER_ID=123456789

# Public HTTPS URL where the bot webhook is reachable
# Local dev: your ngrok URL. Production: https://bot.askfajar.com
BOT_WEBHOOK_URL=https://your-ngrok-url.ngrok.io

# ─────────────────────────────────────────────
# Google Tag Gateway (analytics)
# ─────────────────────────────────────────────

# Tag Gateway Cloud Run URL (production: https://tags.askfajar.com)
TAG_GATEWAY_URL=https://tags.askfajar.com/collect

# GA4 Measurement ID (format: G-XXXXXXXXXX)
GA4_MEASUREMENT_ID=G-XXXXXXXXXX

# GA4 API secret for Measurement Protocol
GA4_API_SECRET=your-ga4-api-secret

# ─────────────────────────────────────────────
# AWS
# ─────────────────────────────────────────────

# AWS region for Transcribe and S3 (suggest ap-southeast-1 for Indonesia latency)
AWS_REGION=ap-southeast-1

# S3 bucket for raw audio (podcasts, voice memos) and Transcribe output
AWS_S3_BUCKET=finance-brain-audio

# AWS credentials — for local dev only; Lambda uses its execution role in production
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
